    <worksheet name='Year Over Year Growth'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='yc_companies' name='federated.1eu708l19nclm014nam9812fc87b' />
          </datasources>
          <datasource-dependencies datasource='federated.1eu708l19nclm014nam9812fc87b'>
            <column datatype='string' name='[Batch]' role='dimension' type='nominal' />
            <column caption='Tech Segments' datatype='string' name='[Calculation_1246891015405570]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF CONTAINS(UPPER([Company Name]), &apos; AI &apos;) OR &#13;&#10;   CONTAINS(UPPER([Company Name]), &apos;AI &apos;) OR &#13;&#10;   CONTAINS(UPPER([Sub Industry]), &apos;AI&apos;) OR &#13;&#10;   CONTAINS(UPPER([Sub Industry]), &apos;ARTIFICIAL INTELLIGENCE&apos;) &#13;&#10;   THEN &apos;AI&apos;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(UPPER([Sub Industry]), &apos;CRYPTO&apos;) OR &#13;&#10;       CONTAINS(UPPER([Sub Industry]), &apos;BLOCKCHAIN&apos;) OR &#13;&#10;       CONTAINS(UPPER([Sub Industry]), &apos;WEB3&apos;) OR&#13;&#10;       CONTAINS(UPPER([Company Name]), &apos;CRYPTO&apos;)&#13;&#10;       THEN &apos;Web3&apos;&#13;&#10;&#13;&#10;ELSEIF [Industry] = &apos;B2B&apos; OR CONTAINS(UPPER([Sub Industry]), &apos;SAAS&apos;) &#13;&#10;       THEN &apos;SaaS&apos;&#13;&#10;&#13;&#10;ELSE &apos;Other&apos;&#13;&#10;END' />
            </column>
            <column aggregation='Sum' caption='Batch Year' datatype='integer' name='[Calculation_1246891015602179]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='INT(RIGHT([Batch], 4))' />
            </column>
            <column caption='YoY Growth %' datatype='real' name='[Calculation_1246891016802308]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(COUNT([Company Name]) - LOOKUP(COUNT([Company Name]), -1)) / ABS(LOOKUP(COUNT([Company Name]), -1))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='string' name='[Company Name]' role='dimension' type='nominal' />
            <column datatype='string' name='[Industry]' role='dimension' type='nominal' />
            <column datatype='string' name='[Sub Industry]' role='dimension' type='nominal' />
            <column-instance column='[Company Name]' derivation='Count' name='[cnt:Company Name:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1246891015405570]' derivation='None' name='[none:Calculation_1246891015405570:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1246891015602179]' derivation='None' name='[none:Calculation_1246891015602179:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Calculation_1246891016802308]' derivation='User' name='[usr:Calculation_1246891016802308:qk:2]' pivot='key' type='quantitative'>
              <table-calc ordering-field='[federated.1eu708l19nclm014nam9812fc87b].[Calculation_1246891015602179]' ordering-type='Field' />
            </column-instance>
            <column-instance column='[Calculation_1246891016802308]' derivation='User' name='[usr:Calculation_1246891016802308:qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Rows' />
            </column-instance>
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1eu708l19nclm014nam9812fc87b].[none:Calculation_1246891015405570:nk]'>
