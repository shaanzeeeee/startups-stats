      <aliases enabled='yes' />
      <column datatype='string' name='[Batch]' role='dimension' type='nominal' />
      <column caption='Tech Segments' datatype='string' name='[Calculation_1246891015405570]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS(UPPER([Company Name]), &apos; AI &apos;) OR &#13;&#10;   CONTAINS(UPPER([Company Name]), &apos;AI &apos;) OR &#13;&#10;   CONTAINS(UPPER([Sub Industry]), &apos;AI&apos;) OR &#13;&#10;   CONTAINS(UPPER([Sub Industry]), &apos;ARTIFICIAL INTELLIGENCE&apos;) &#13;&#10;   THEN &apos;AI&apos;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(UPPER([Sub Industry]), &apos;CRYPTO&apos;) OR &#13;&#10;       CONTAINS(UPPER([Sub Industry]), &apos;BLOCKCHAIN&apos;) OR &#13;&#10;       CONTAINS(UPPER([Sub Industry]), &apos;WEB3&apos;) OR&#13;&#10;       CONTAINS(UPPER([Company Name]), &apos;CRYPTO&apos;)&#13;&#10;       THEN &apos;Web3&apos;&#13;&#10;&#13;&#10;ELSEIF [Industry] = &apos;B2B&apos; OR CONTAINS(UPPER([Sub Industry]), &apos;SAAS&apos;) &#13;&#10;       THEN &apos;SaaS&apos;&#13;&#10;&#13;&#10;ELSE &apos;Other&apos;&#13;&#10;END' />
      </column>
      <column aggregation='Sum' caption='Batch Year' datatype='integer' name='[Calculation_1246891015602179]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='INT(RIGHT([Batch], 4))' />
      </column>
      <column caption='YoY Growth %' datatype='real' name='[Calculation_1246891016802308]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(COUNT([Company Name]) - LOOKUP(COUNT([Company Name]), -1)) / ABS(LOOKUP(COUNT([Company Name]), -1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Survival Rate' datatype='real' name='[Calculation_1246891019259909]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Company Status] != &apos;Inactive&apos; THEN [Company Name] END) / COUNT([Company Name])' />
      </column>
      <column caption='Acquisition Rate' datatype='real' name='[Calculation_1246891019337734]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Company Status] = &apos;Acquired&apos; THEN [Company Name] END) / COUNT([Company Name])' />
      </column>
      <column aggregation='CountD' caption='Work Type' datatype='string' name='[Calculation_1246891042885640]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([Company Address]) OR CONTAINS(LOWER([Company Address]), &apos;remote&apos;) OR [Company Country] = &apos;Remote&apos;&#13;&#10;THEN &apos;Remote / Hybrid&apos;&#13;&#10;ELSE &apos;Office-Based&apos;&#13;&#10;END' />
      </column>
      <column caption='Total Companies' datatype='real' name='[Calculation_1246891044769802]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='' />
      </column>
      <column caption='Failure Rate' datatype='real' name='[Calculation_1246891048087563]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Company Status] = &apos;Inactive&apos; THEN [Company Name] END) / COUNT([Company Name])' />
      </column>
      <column caption='Public Rate' datatype='real' name='[Calculation_1246891048153100]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Company Status] = &apos;Public&apos; THEN [Company Name] END) / COUNT([Company Name])' />
      </column>
